# Anthropic Claude API (required)
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity API (optional — used by fact_checker)
PERPLEXITY_API_KEY=

# Google APIs (NOT required for the demo. Used only when the orchestrator
# is wired to Google Sheets / Drive in a private deployment.)
GOOGLE_SHEET_ID=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=config/service_account.json

# App
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.3
SKILL_INJECTION_ENABLED=false
